{
  "version": 2,
  "installCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "cd artifacts/plutonium-smp && ./node_modules/.bin/vite build --config vite.config.ts --outDir ../../public --emptyOutDir",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
