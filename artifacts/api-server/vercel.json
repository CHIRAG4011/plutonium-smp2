{
  "version": 2,
  "installCommand": "cd ../.. && NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build && cd ../plutonium-smp && pnpm run build && mkdir -p ../api-server/public && cp -r dist/public/. ../api-server/public/",
  "outputDirectory": "public",
  "functions": {
    "api/index.cjs": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
