# =============================================================================
#  PLUTONIUM SMP — API SERVER ENVIRONMENT VARIABLES
# =============================================================================
#
#  HOW TO USE
#  ----------
#  Local development:
#    cp env/api.env.example artifacts/api-server/.env
#    Then fill in the values below.
#
#  Vercel production:
#    Copy each variable into your Vercel project's Environment Variables page.
#    (Project → Settings → Environment Variables)
#
# =============================================================================


# =============================================================================
#  SERVER
# =============================================================================

# Port the API server listens on.
# Local:      3001  (Vite proxies /api → this port automatically)
# Vercel:     Not needed — Vercel assigns the port automatically.
PORT=3001

# The full public-facing URL of this API server.
# No trailing slash. This is the most important variable for production.
#
# Why it matters:
#   Discord OAuth uses this to build the redirect URI:
#   APP_URL + /api/auth/discord/callback
#   If this is wrong, Discord login will fail with "redirect_uri_mismatch".
#
# Local:       http://localhost:3001
# Vercel:      https://your-api-project.vercel.app
# Custom domain: https://api.yourdomain.com
APP_URL=http://localhost:3001


# =============================================================================
#  DATABASE (MongoDB)
# =============================================================================

# MongoDB connection string.
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE
#
# Recommended hosted providers (free tiers available):
#   MongoDB Atlas: https://www.mongodb.com/cloud/atlas  (official, recommended)
#   Railway:       https://railway.app                   (easy setup)
#
# Local (MongoDB Community):  mongodb://localhost:27017/plutonium
# Atlas example: mongodb+srv://user:pass@cluster0.abc12.mongodb.net/plutonium?retryWrites=true&w=majority
#
MONGODB_URI=mongodb://localhost:27017/plutonium


# =============================================================================
#  AUTHENTICATION
# =============================================================================

# Secret key used to sign and verify JWT tokens.
#
# IMPORTANT:
#   - Must be long (64+ chars) and completely random.
#   - Never share this or commit it to version control.
#   - Changing this value will log out all existing users.
#
# Generate a secure value:
#   openssl rand -hex 64
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_this_with_a_very_long_random_string_at_least_64_chars


# =============================================================================
#  CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Comma-separated list of frontend origins that are allowed to call this API.
#
# Local:       http://localhost:5173
# Production:  https://your-frontend.vercel.app,https://yourdomain.com
#
# Leave blank to allow ALL origins (only acceptable for local dev).
ALLOWED_ORIGINS=http://localhost:5173


# =============================================================================
#  DISCORD OAUTH
# =============================================================================
#
# SETUP STEPS:
#   1. Go to https://discord.com/developers/applications
#   2. Click "New Application" → give it a name (e.g. "Plutonium SMP")
#   3. Open OAuth2 → General in the left sidebar
#   4. Under "Redirects", click "Add Redirect" and enter:
#        Local:       http://localhost:3001/api/auth/discord/callback
#        Production:  https://your-api.vercel.app/api/auth/discord/callback
#   5. Click "Save Changes"
#   6. Copy the Client ID and Client Secret below.
#
# The redirect URI format is always:  APP_URL + /api/auth/discord/callback
# (APP_URL is the variable above — keep them in sync)

DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret


# =============================================================================
#  EMAIL
# =============================================================================
#
# The API sends transactional emails for:
#   - OTP codes (login, registration, checkout)
#   - Welcome emails on signup
#   - Login notifications
#
# Choose ONE option below (A or B). Option A is recommended for production.
#
# ─── Option A: Resend (recommended) ──────────────────────────────────────────
#
# Sign up at https://resend.com (free tier: 100 emails/day)
# Steps:
#   1. Create account → verify your sending domain
#   2. API Keys → Create API Key
#   3. Paste the key below
#
RESEND_API_KEY=re_your_resend_api_key_here

# ─── Option B: SMTP (fallback) ───────────────────────────────────────────────
#
# Used automatically if RESEND_API_KEY is not set.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_gmail_app_password   ← NOT your Gmail password
#             (generate at: Google Account → Security → App passwords)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# The "From" address shown on all outgoing emails.
SMTP_FROM=Plutonium SMP <noreply@yourdomain.com>


# =============================================================================
#  LOGGING
# =============================================================================

# Controls how verbose the server logs are.
# Options: trace | debug | info | warn | error | fatal
#
# Local:       debug  (see all requests and DB queries)
# Production:  info   (only important events)
LOG_LEVEL=info
